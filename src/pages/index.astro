---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getAllProjects } from '../utils/projects';

const projects = getAllProjects();
---

<BaseLayout title="elymas.github.io - Project Hub">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-surface-900 dark:text-surface-100">
          Welcome to
          <span class="text-primary-600 dark:text-primary-400">elymas</span>.github.io
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-surface-600 dark:text-surface-400 max-w-2xl mx-auto leading-relaxed">
          A central hub for all projects hosted on GitHub Pages.
          Explore blogs, documentation, tutorials, and more.
        </p>
      </div>
    </div>
    <!-- Decorative gradient -->
    <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-primary-400/10 dark:bg-primary-600/5 blur-3xl"></div>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-20">
    <div class="mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-surface-900 dark:text-surface-100">
        Projects
      </h2>
      <p class="mt-2 text-surface-600 dark:text-surface-400">
        Browse the collection of sites and applications.
      </p>
    </div>
    <ProjectGrid projects={projects} />
  </section>
</BaseLayout>
