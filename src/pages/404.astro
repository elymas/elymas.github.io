---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found - float on">
  <section class="flex flex-1 flex-col items-center justify-center px-4 py-24 text-center">
    <!-- Cloud icon matching brand motif -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 36 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="mb-8 h-16 w-24 text-surface-400 dark:text-surface-600"
      aria-hidden="true"
    >
      <path d="M8 18c-2 0-3.5-1.3-3.5-3 0-1.6 1.1-2.8 2.7-3C7.2 8.2 10 6 13.5 6c2.8 0 5.2 1.7 6.1 4.2.5-.2 1-.3 1.6-.3 2.5 0 4.5 1.8 4.5 4.1 0 2.2-1.9 4-4.2 4H8z" />
      <path d="M5.5 19c2 1.2 5.5 1.8 9 .5s6.5-.2 9.5 1" opacity="0.5" />
    </svg>

    <h1
      class="mb-3 text-6xl font-semibold tracking-tight text-charcoal dark:text-cream sm:text-8xl"
      style="font-family: Georgia, 'Times New Roman', serif;"
    >
      404
    </h1>

    <p class="mb-10 text-lg text-surface-500 dark:text-surface-400">
      This page floated away.
    </p>

    <a
      href="/"
      class="inline-flex items-center rounded-lg bg-charcoal px-6 py-3 text-sm font-medium text-cream transition-opacity hover:opacity-80 dark:bg-cream dark:text-charcoal"
    >
      Return Home
    </a>
  </section>
</BaseLayout>
