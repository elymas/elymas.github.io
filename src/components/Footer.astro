---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-paper-2 dark:border-surface-800 bg-paper dark:bg-ink">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2 text-sm text-surface-500 dark:text-surface-400">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-6" aria-hidden="true">
          <path d="M8 18c-2 0-3.5-1.3-3.5-3 0-1.6 1.1-2.8 2.7-3C7.2 8.2 10 6 13.5 6c2.8 0 5.2 1.7 6.1 4.2.5-.2 1-.3 1.6-.3 2.5 0 4.5 1.8 4.5 4.1 0 2.2-1.9 4-4.2 4H8z" />
        </svg>
        <span>&copy; {currentYear} float on. All rights reserved.</span>
      </div>
      <a
        href="https://github.com/elymas"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-surface-500 dark:text-surface-400 hover:text-ink dark:hover:text-paper transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
          <path d="M9 18c-4.51 2-5-2-7-2" />
        </svg>
        <span>github.com/elymas</span>
      </a>
    </div>
  </div>
</footer>
