---
import type { Project } from '../types/project';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const typeColors: Record<string, { bg: string; text: string }> = {
  blog: { bg: 'bg-emerald-100 dark:bg-emerald-900/30', text: 'text-emerald-700 dark:text-emerald-400' },
  docs: { bg: 'bg-primary-100 dark:bg-primary-900/30', text: 'text-primary-700 dark:text-primary-400' },
  landing: { bg: 'bg-purple-100 dark:bg-purple-900/30', text: 'text-purple-700 dark:text-purple-400' },
  app: { bg: 'bg-orange-100 dark:bg-orange-900/30', text: 'text-orange-700 dark:text-orange-400' },
  tutorial: { bg: 'bg-amber-100 dark:bg-amber-900/30', text: 'text-amber-700 dark:text-amber-400' },
  portfolio: { bg: 'bg-rose-100 dark:bg-rose-900/30', text: 'text-rose-700 dark:text-rose-400' },
};

const colors = typeColors[project.type] || typeColors.app;
const isComingSoon = project.status === 'coming-soon';
const isArchived = project.status === 'archived';
---

{isComingSoon ? (
  <div
    class:list={[
      'group block rounded-xl border border-paper-2 dark:border-surface-800 bg-paper dark:bg-surface-800 p-6 transition-all duration-200',
      'opacity-80 cursor-default',
      isArchived && 'opacity-60',
    ]}
  >
    <div class="flex items-start justify-between gap-3 mb-3">
      <span class:list={['inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium', colors.bg, colors.text]}>
        {project.type}
      </span>
      <span class="inline-flex items-center rounded-full bg-paper-2 dark:bg-surface-800 px-2.5 py-0.5 text-xs font-medium text-surface-600 dark:text-surface-400">
        Coming Soon
      </span>
    </div>

    <h3 class="font-serif text-lg font-semibold text-ink dark:text-paper mb-2 transition-colors">
      {project.name}
    </h3>

    <p class="text-sm text-surface-500 dark:text-surface-400 mb-4 line-clamp-3">
      {project.description}
    </p>

    <div class="flex flex-wrap gap-1.5">
      {project.techStack.map((tech) => (
        <span class="inline-flex items-center rounded-md bg-paper-2 dark:bg-surface-800 px-2 py-0.5 text-xs text-surface-600 dark:text-surface-400">
          {tech}
        </span>
      ))}
    </div>
  </div>
) : (
  <a
    href={project.url}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'group block rounded-xl border border-paper-2 dark:border-surface-800 bg-paper dark:bg-surface-800 p-6 transition-all duration-200',
      'hover:shadow-lg hover:border-primary-400 dark:hover:border-primary-600 hover:-translate-y-0.5',
      isArchived && 'opacity-60',
    ]}
  >
    <div class="flex items-start justify-between gap-3 mb-3">
      <span class:list={['inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium', colors.bg, colors.text]}>
        {project.type}
      </span>
    </div>

    <h3 class="font-serif text-lg font-semibold text-ink dark:text-paper mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
      {project.name}
    </h3>

    <p class="text-sm text-surface-500 dark:text-surface-400 mb-4 line-clamp-3">
      {project.description}
    </p>

    <div class="flex flex-wrap gap-1.5">
      {project.techStack.map((tech) => (
        <span class="inline-flex items-center rounded-md bg-paper-2 dark:bg-surface-800 px-2 py-0.5 text-xs text-surface-600 dark:text-surface-400">
          {tech}
        </span>
      ))}
    </div>
  </a>
)}
