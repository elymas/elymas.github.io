---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 z-50 border-b border-surface-200 dark:border-surface-800 bg-cream/80 dark:bg-charcoal/80 backdrop-blur-md">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 text-lg font-normal text-charcoal dark:text-cream hover:opacity-75 transition-opacity">
        <!-- Cloud icon matching brand sheet -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-9" aria-hidden="true">
          <path d="M8 18c-2 0-3.5-1.3-3.5-3 0-1.6 1.1-2.8 2.7-3C7.2 8.2 10 6 13.5 6c2.8 0 5.2 1.7 6.1 4.2.5-.2 1-.3 1.6-.3 2.5 0 4.5 1.8 4.5 4.1 0 2.2-1.9 4-4.2 4H8z" />
          <path d="M5.5 19c2 1.2 5.5 1.8 9 .5s6.5-.2 9.5 1" opacity="0.5" />
        </svg>
        <span class="font-serif tracking-tight" style="font-family: Georgia, 'Times New Roman', serif;">float on</span>
      </a>
      <nav class="flex items-center gap-6" aria-label="Main navigation">
        <a
          href="/#projects"
          class="text-xs sm:text-sm text-surface-600 dark:text-surface-300 hover:text-charcoal dark:hover:text-cream transition-colors"
        >
          Projects
        </a>
        <a
          href="https://github.com/elymas"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs sm:text-sm text-surface-600 dark:text-surface-300 hover:text-charcoal dark:hover:text-cream transition-colors"
          aria-label="GitHub Profile"
        >
          GitHub
        </a>
        <ThemeToggle />
      </nav>
    </div>
  </div>
</header>
